{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5438;Database=subscription;Username=admin;Password=root"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Elasticsearch" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    }
  },
  "ExternalServices": {
    "YookassaApi": "https://api.yookassa.ru/v3"
  },
  "Elastic": {
    "ServiceName": "subscription"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "subscription-service",
    "AutoOffsetReset": "Earliest"
  },
  "YooKassa": {
    "ShopId": "your-shop-id",
    "SecretKey": "your-secret-key",
    "BaseUrl": "https://api.yookassa.ru/v3"
  }

}
